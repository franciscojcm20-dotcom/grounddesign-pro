{
  "name": "grounddesing-pro-root",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm -F @gdp/api dev\" \"pnpm -F @gdp/web dev\"",
    "test": "pnpm -r test",
    "test:legacy": "node --test tests/motors.test.js",
