  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"]
  }
}
