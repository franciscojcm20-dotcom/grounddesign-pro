# GroundDesign Pro — Variables de entorno
# Copiar a .env y ajustar valores

# Base de datos
DB_PASSWORD=gdpdev
DATABASE_URL=postgres://gdp:gdpdev@localhost:5432/grounddesign

# API
PORT=3001
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
WEB_URL=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Email (SMTP) — dejar vacío para modo dev (log-only, sin envío real)
# Proveedores recomendados: Resend, SendGrid, Mailgun, Gmail SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=GroundDesign Pro <noreply@grounddesign.pro>

# Stripe billing — dejar vacío para modo demo (sin pagos reales)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_INDIVIDUAL=
STRIPE_PRICE_PROFESSIONAL=

# Sentry — observabilidad/tracking de errores. Dejar vacío para deshabilitarlo
# por completo (no hay dependencia dura: la app funciona igual sin esto).
# API (server-side):
SENTRY_DSN=
# Web — mismo proyecto de Sentry, dos variables porque el cliente necesita el
# prefijo NEXT_PUBLIC_ para quedar expuesto al bundle del navegador:
NEXT_PUBLIC_SENTRY_DSN=
# Opcional: solo si quieres que el build suba source maps a Sentry (mejores
# stack traces). Sin esto, el build funciona igual, solo con traces menos legibles.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
