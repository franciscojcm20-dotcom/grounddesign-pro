{
  "name": "@gdp/engines-math",
  "version": "0.1.0",
  "description": "Pure math engines for grounding system design (IEEE 80/81)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types":  "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-cjs.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types tests/motors.test.ts"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22"
  }
}
